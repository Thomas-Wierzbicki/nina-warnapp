<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NINA Warnungen Deutschland by DA1TWD</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-main: #e0e0e0;
            --text-muted: #aaaaaa;
            --color-minor: #fbc02d;
            --color-moderate: #f57c00;
            --color-severe: #d32f2f;
            --color-extreme: #7b1fa2;
            --color-unknown: #757575;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
        }

        header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 10px;
            flex-wrap: wrap; gap: 15px;
        }

        h1 { margin: 0; font-size: 1.8rem; }
        .header-controls { display: flex; align-items: center; gap: 15px; }
        #last-update { color: var(--text-muted); font-size: 0.9rem; }

        select {
            background-color: #333; color: #fff; border: 1px solid #555;
            padding: 8px 12px; border-radius: 4px; font-size: 0.95rem;
            cursor: pointer; outline: none;
        }
        select:focus { border-color: var(--color-moderate); }

        #map {
            height: 450px; width: 100%; border-radius: 8px; margin-bottom: 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5); border: 1px solid #333; z-index: 1;
        }

        .leaflet-popup-content-wrapper { background-color: var(--card-bg); color: var(--text-main); border-radius: 8px; }
        .leaflet-popup-tip { background-color: var(--card-bg); }
        .leaflet-popup-content h4 { margin: 0 0 5px 0; border-bottom: 1px solid #444; padding-bottom: 5px; }
        .leaflet-popup-content ul { margin: 0; padding-left: 15px; font-size: 0.9rem; }

        .state-section { margin-bottom: 40px; }
        .state-title { font-size: 1.4rem; margin-bottom: 15px; color: #fff; border-bottom: 2px solid #333; padding-bottom: 5px; }

        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px; }

        .card {
            background-color: var(--card-bg); border-radius: 8px; padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3); border-top: 5px solid var(--color-unknown);
            display: flex; flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            position: relative;
            max-height: 250px; 
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.6);
            z-index: 10; 
        }

        .severity-Minor { border-top-color: var(--color-minor); }
        .severity-Moderate { border-top-color: var(--color-moderate); }
        .severity-Severe { border-top-color: var(--color-severe); }
        .severity-Extreme { border-top-color: var(--color-extreme); }

        .card h3 { margin: 0 0 10px 0; font-size: 1.2rem; line-height: 1.3; }
        
        .card-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        
        .badge {
            display: inline-block; padding: 3px 8px; border-radius: 4px;
            font-size: 0.8rem; font-weight: bold;
            text-transform: uppercase; background-color: #333;
        }

        .date-badge { font-size: 0.8rem; color: var(--text-muted); }

        .severity-Minor .badge { color: var(--color-minor); }
        .severity-Moderate .badge { color: var(--color-moderate); }
        .severity-Severe .badge { color: var(--color-severe); }
        .severity-Extreme .badge { color: var(--color-extreme); }

        .description { 
            font-size: 0.95rem; line-height: 1.5; margin-bottom: 15px; color: #ccc;
            display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
            overflow: hidden; text-overflow: ellipsis;
        }

        .card:hover .description {
            display: block; overflow-y: auto; max-height: 150px; padding-right: 5px; 
        }
        
        .description::-webkit-scrollbar { width: 6px; }
        .description::-webkit-scrollbar-track { background: transparent; }
        .description::-webkit-scrollbar-thumb { background: #555; border-radius: 3px; }
        .description::-webkit-scrollbar-thumb:hover { background: #777; }

        .all-clear { text-align: center; padding: 50px; background: var(--card-bg); border-radius: 8px; color: #4caf50; font-size: 1.2rem; grid-column: 1 / -1; }
    </style>
</head>
<body>

    <header>
        <h1>🚨 NINA Warnungen Deutschland by DA1TWD</h1>
        <div class="header-controls">
            <select id="severity-filter">
                <option value="1">Alle (ab Gering / Gelb)</option>
                <option value="2" selected>Ab Mittel (Orange)</option>
                <option value="3">Ab Hoch (Rot)</option>
                <option value="4">Nur Extrem (Lila)</option>
            </select>
            <div id="last-update">Lade Daten...</div>
        </div>
    </header>

    <div id="map"></div>
    <div id="dashboard"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        const map = L.map('map').setView([51.1657, 10.4515], 6);
        
        const baseLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 19
        }).addTo(map);

        const markersLayer = L.layerGroup().addTo(map);

        let radarLayer = null;
        async function loadRainRadar() {
            try {
                const response = await fetch('https://api.rainviewer.com/public/weather-maps.json');
                const data = await response.json();
                const latestFrame = data.radar.past[data.radar.past.length - 1];
                const tileUrl = `https://tilecache.rainviewer.com${latestFrame.path}/256/{z}/{x}/{y}/2/1_1.png`;

                if (radarLayer) map.removeLayer(radarLayer);

                radarLayer = L.tileLayer(tileUrl, {
                    opacity: 0.5, zIndex: 5 
                }).addTo(map);
            } catch (error) {
                console.error("Fehler beim Laden des Regenradars:", error);
            }
        }
        loadRainRadar();
        setInterval(loadRainRadar, 10 * 60 * 1000); 

        const stateCoords = {
            "Baden-Württemberg": [48.6616, 9.0392], "Bayern": [48.7904, 11.4979],
            "Berlin": [52.5200, 13.4050], "Brandenburg": [52.4125, 12.5316],
            "Bremen": [53.0793, 8.8017], "Hamburg": [53.5511, 9.9937],
            "Hessen": [50.6521, 9.1624], "Mecklenburg-Vorpommern": [53.6127, 12.4296],
            "Niedersachsen": [52.6367, 9.8451], "Nordrhein-Westfalen": [51.4332, 7.6616],
            "Rheinland-Pfalz": [49.8153, 7.3240], "Saarland": [49.3964, 6.9817],
            "Sachsen": [51.1045, 13.2017], "Sachsen-Anhalt": [51.9503, 11.6923],
            "Schleswig-Holstein": [54.2194, 9.6961], "Thüringen": [50.8278, 11.0215]
        };

        const severityConfig = {
            "Extreme":  { color: "#7b1fa2" },
            "Severe":   { color: "#d32f2f" },
            "Moderate": { color: "#f57c00" },
            "Minor":    { color: "#fbc02d" },
            "Unknown":  { color: "#757575" }
        };

        function formatDate(dateString) {
            if (!dateString) return "Keine Zeitangabe";
            const dateObj = new Date(dateString);
            return dateObj.toLocaleDateString('de-DE') + ', ' + dateObj.toLocaleTimeString('de-DE', {hour: '2-digit', minute:'2-digit'}) + ' Uhr';
        }

        async function fetchWarnings() {
            const minLevel = document.getElementById('severity-filter').value;
            try {
                const response = await fetch(`nina_current.json?minLevel=${minLevel}&t=${new Date().getTime()}`);
                if (!response.ok) throw new Error("Netzwerkfehler");
                
                const data = await response.json(); 
                
                const now = new Date();
                document.getElementById('last-update').innerText = `Letztes Update: ${now.toLocaleTimeString('de-DE')} Uhr`;
                
                renderDashboard(data);
            } catch (error) {
                console.error("Fehler:", error);
                document.getElementById('last-update').innerText = "⚠️ Fehler beim Laden der Daten.";
            }
        }

        function renderDashboard(data) {
            const dashboard = document.getElementById('dashboard');
            dashboard.innerHTML = ''; 
            markersLayer.clearLayers(); 

            let totalDisplayedWarnings = 0;

            for (const [stateName, warnings] of Object.entries(data)) {
                if (warnings.length > 0) {
                    totalDisplayedWarnings += warnings.length;

                    if (stateCoords[stateName] && stateName !== "Überregional / Ohne genaue Ortsangabe") {
                        warnings.forEach(w => {
                            const sev = w.payload?.data?.severity || "Unknown";
                            const title = w.payload?.data?.headline || w.i18nTitle?.de || "Warnung";
                            const description = w.payload?.data?.description || "";
                            const sentDate = w.payload?.data?.sent || "";
                            const formattedDate = formatDate(sentDate);
                            const markerColor = severityConfig[sev]?.color || "#757575";

                            try {
                                if (w.polygons && w.polygons.length > 0) {
                                    w.polygons.forEach(polyCoords => {
                                        const polygonLayer = L.polygon(polyCoords, {
                                            color: markerColor, weight: 2,
                                            fillColor: markerColor, fillOpacity: 0.4
                                        });
                                        
                                        polygonLayer.bindPopup(`<strong>${title}</strong><br><span style="font-size: 0.8em; color: #aaa;">${formattedDate}</span><br>Stufe: ${sev}<br><div style="max-height: 200px; overflow-y: auto; margin-top: 10px; font-size: 0.9em;">${description}</div>`);
                                        
                                        polygonLayer.on('mouseover', function () { this.setStyle({ fillOpacity: 0.7, weight: 4 }); });
                                        polygonLayer.on('mouseout', function () { this.setStyle({ fillOpacity: 0.4, weight: 2 }); });

                                        polygonLayer.addTo(markersLayer);
                                    });
                                } else {
                                    const circle = L.circleMarker(stateCoords[stateName], {
                                        radius: 10, fillColor: markerColor, color: markerColor,
                                        weight: 2, opacity: 0.8, fillOpacity: 0.5
                                    });
                                    circle.bindPopup(`<strong>${title}</strong><br><span style="font-size: 0.8em; color: #aaa;">${formattedDate}</span><br>(Genaue Geodaten fehlen)<br><div style="max-height: 200px; overflow-y: auto; margin-top: 10px; font-size: 0.9em;">${description}</div>`);
                                    circle.addTo(markersLayer);
                                }
                            } catch (error) {
                                console.warn("Fehler beim Zeichnen auf der Karte:", title, error);
                            }
                        });
                    }

                    const section = document.createElement('div');
                    section.className = 'state-section';
                    
                    const title = document.createElement('h2');
                    title.className = 'state-title';
                    title.innerText = `${stateName} (${warnings.length} Warnungen)`;
                    section.appendChild(title);

                    const grid = document.createElement('div');
                    grid.className = 'grid';

                    warnings.forEach(w => {
                        const payloadData = w.payload?.data || {};
                        const sev = payloadData.severity || "Unknown";
                        const headline = payloadData.headline || w.i18nTitle?.de || "Warnung ohne Titel";
                        const description = payloadData.description || "Bitte die NINA-App prüfen.";
                        const formattedDate = formatDate(payloadData.sent);

                        const card = document.createElement('div');
                        card.className = `card severity-${sev}`;
                        card.innerHTML = `
                            <h3>${headline}</h3>
                            <div class="card-meta">
                                <span class="badge">${sev}</span>
                                <span class="date-badge">${formattedDate}</span>
                            </div>
                            <div class="description">${description}</div>
                        `;
                        grid.appendChild(card);
                    });

                    section.appendChild(grid);
                    dashboard.appendChild(section);
                }
            }

            if (totalDisplayedWarnings === 0) {
                dashboard.innerHTML = '<div class="all-clear">✅ Aktuell liegen für die gewählte Warnstufe keine Warnungen vor.</div>';
            }
        }

        document.getElementById('severity-filter').addEventListener('change', fetchWarnings);

        fetchWarnings(); 
        setInterval(fetchWarnings, 60000); 
    </script>
</body>
</html>
